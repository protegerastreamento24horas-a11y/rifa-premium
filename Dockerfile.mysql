# Dockerfile para MySQL no Render
FROM mysql:8.0

# Configurações otimizadas para Render
ENV MYSQL_ROOT_PASSWORD=rootpassword123
ENV MYSQL_DATABASE=rifa_premium
ENV MYSQL_USER=rifa_user
ENV MYSQL_PASSWORD=rifa_pass123

# Porta padrão do MySQL
EXPOSE 3306

# Volume para persistência de dados
VOLUME /var/lib/mysql

# Comando de inicialização
CMD ["mysqld"]
