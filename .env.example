# Exemplo de variáveis de ambiente para Railway
# Copie estas variáveis no Dashboard do Railway

# Banco de dados (Railway gera automaticamente ao adicionar MySQL)
MYSQLHOST=seu-host-mysql.railway.internal
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=sua-senha
MYSQLDATABASE=railway

# Ou use estas variáveis personalizadas
DB_SERVER=${MYSQLHOST}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}
DB_NAME=${MYSQLDATABASE}
DB_PORT=${MYSQLPORT}

# URL da aplicação
BASE_URL=https://seu-projeto.railway.app/
RAILWAY_STATIC_URL=seu-projeto.railway.app
